<div class="subhead" id="conversa"><h2>Conversa</h2></div>

<%# READ-ONLY. Conteudo NAO confiavel. O `text` chega como HTML JA sanitizado pelo %>
<%# MarkdownRenderer (F5.2); o restante usa auto-escape do ERB. Proibido AQUI: %>
<%# html_safe, raw, simple_format, sanitize (a sanitizacao vive so no renderer). %>
<% case status %>
<% when :ok %>
  <% if mismatched.positive? %>
    <p class="muted">⚠ <%= mismatched %> linha(s) ignorada(s) por divergência de índice (considere reindexar os turnos).</p>
  <% end %>
  <% if turns.empty? %>
    <p class="muted">Nenhum turno nesta página.</p>
  <% else %>
    <ol class="turns">
      <% turns.each do |turn| %>
        <li class="turn turn--<%= role_class(turn.role) %>">
          <div class="turn__head">
            <span class="badge badge--<%= role_tone(turn.role) %> turn__role"><%= role_label(turn.role) %></span>
            <span class="muted turn__meta"><%= timestamp_label(turn.ts) %> · linha <%= turn.line_no %></span>
          </div>
          <% if turn.text.present? %>
            <div class="turn__body markdown"><%= turn_body_html(turn) %></div>
          <% end %>
          <% if tool_input?(turn) %>
            <div class="turn__tool">
              <% if turn.tool.present? %>
                <span class="muted">tool: <%= turn.tool %></span>
              <% end %>
              <pre class="mono turn__pre"><%= tool_input_text(turn) %></pre>
            </div>
          <% end %>
        </li>
      <% end %>
    </ol>

    <% if total_pages > 1 %>
      <%# Navegação amigável (primeira/anterior/próxima/última) — mesmo padrão das listas. %>
      <%= pagination_nav(current: page, total_pages: total_pages, total_count: total, unit: "turno(s)", aria: "Paginação dos turnos", url: ->(p) { page_url(p) }) %>
    <% end %>

    <%# Seletor de turnos por página (allowlist; sem "todos" irrestrito). %>
    <% if per_page.present? && per_page_options.any? && total > per_page_options.min %>
      <div class="turns-per-page muted">
        Turnos por página:
        <% per_page_options.each do |size| %>
          <% if size == per_page %>
            <strong class="turns-per-page__current"><%= size %></strong>
          <% else %>
            <%= link_to size, per_page_url(size), class: "turns-per-page__opt" %>
          <% end %>
        <% end %>
      </div>
    <% end %>
  <% end %>
<% when :stale %>
  <p class="muted">O índice de turnos desta conversa está <strong>desatualizado</strong> em relação à fonte.
  Reindexe os turnos para visualizar o conteúdo.</p>
<% when :empty, :not_found %>
  <p class="muted">Índice de turnos ainda não construído para esta conversa.</p>
<% else %>
  <p class="muted">Turnos indisponíveis no momento.</p>
<% end %>
