<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="App">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%# PB-018 — cores dos status configuráveis via <style nonce> (CSP-safe; sem style inline). %>
    <%= configurable_status_styles_tag if user_signed_in? %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <div class="app-shell">
      <% if user_signed_in? %>
        <aside class="sidebar">
          <div class="sidebar__brand">
            <span class="brand-mark">O</span>
            <span>Omni<span class="brand-sub">Continuity</span></span>
          </div>
          <%= render(SidebarComponent.new(current_path: request.path)) %>
          <div class="sidebar__footer">
            <span class="sidebar__user"><%= current_user.username %></span>
            <%= button_to "Sair", destroy_user_session_path, method: :delete, form_class: "sidebar__logout" %>
          </div>
        </aside>
      <% end %>

      <div class="app-body">
        <% if user_signed_in? %>
          <header class="topbar">
            <%# PB-013 — busca global (GET /search). Funciona sem JS. %>
            <%= form_with url: search_path, method: :get, class: "topbar__search", data: { turbo: false } do |f| %>
              <span class="search-icon" aria-hidden="true">⌕</span>
              <%= f.search_field :q, value: params[:q], placeholder: "Buscar tarefas, conversas, clientes…",
                    "aria-label": "Buscar no Omni", autocomplete: "off" %>
            <% end %>
            <div class="topbar__spacer"></div>
            <%= render "shared/running_timers_banner" %>
            <span class="topbar__hint">Baseline visual</span>
          </header>
        <% end %>

        <main class="app-main">
          <% flash.each do |type, message| %>
            <div class="flash flash--<%= type %>"><%= message %></div>
          <% end %>
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
