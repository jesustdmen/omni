<% content_for :title, "Apontamento" %>

<%# PB-013b — breadcrumb acessível; "Apontamentos" preserva a origem quando houver. %>
<nav class="breadcrumb" aria-label="Breadcrumb">
  <%= link_to "Apontamentos", (@return_to.presence || time_entries_path) %>
  <span class="sep">/</span>
  <%= link_to task_code_label(@time_entry.task), @time_entry.task %><%# PB-014 %>
</nav>

<div class="page-head">
  <div class="page-head__titles">
    <h1>Apontamento</h1>
    <div class="badge-row">
      <%= @time_entry.is_running ? tag.span("Em execução", class: "badge badge--info") : tag.span("Parado", class: "badge badge--neutral") %>
    </div>
  </div>
  <div class="page-head__actions">
    <%= link_to "Editar", edit_time_entry_path(@time_entry, return_to: @return_to), class: "btn btn--outline btn--sm" %>
    <%= button_to "Excluir", time_entry_path(@time_entry, return_to: @return_to), method: :delete,
          class: "btn btn--ghost btn--sm", form_class: "inline",
          data: { turbo_confirm: "Excluir apontamento?" } %>
  </div>
</div>

<div class="card">
  <dl>
    <dt>Tarefa</dt><dd><%= link_to task_code_label(@time_entry.task), @time_entry.task %></dd><%# PB-014 %>
    <dt>Data</dt><dd><%= @time_entry.date %></dd>
    <dt>Início</dt><dd><%= @time_entry.start_time&.strftime("%d/%m/%Y %H:%M") %></dd>
    <dt>Término</dt><dd><%= @time_entry.end_time&.strftime("%d/%m/%Y %H:%M") || "—" %></dd>
    <dt>Duração</dt><dd><%= duration_label(@time_entry.duration) %></dd>
    <dt>Em execução</dt><dd><%= @time_entry.is_running ? "Sim" : "Não" %></dd>
    <dt>Descrição</dt><dd><%= @time_entry.description.presence || "—" %></dd>
  </dl>
</div>

<%= link_to "Voltar", (@return_to.presence || time_entries_path), class: "back-link" %>
