<%= form_with model: time_entry do |f| %>
  <%= hidden_field_tag :return_to, @return_to if @return_to.present? %><%# PB-013b %>
  <% if time_entry.errors.any? %>
    <div class="errors">
      <p><%= pluralize(time_entry.errors.count, "erro") %> impediram salvar:</p>
      <ul>
        <% time_entry.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if time_entry.is_running %>
    <%# PB-003c — timer em andamento: campos temporais read-only; só descrição é editável. %>
    <p class="muted">Timer em andamento — os campos de tempo são geridos pelo cronômetro (iniciar/parar). Apenas a descrição é editável aqui.</p>
    <div><strong>Tarefa:</strong> <%= time_entry.task&.title %></div>
    <div><strong>Início:</strong> <%= local_datetime(time_entry.start_time) %></div>
    <div><%= f.label :description, "Descrição" %><br><%= f.text_area :description, rows: 3 %></div>
  <% else %>
    <div>
      <%= f.label :task_id, "Tarefa" %><br>
      <%# PB-014 — select como "TSK-000001 — Título (Cliente)". %>
      <%= f.select :task_id,
            options_for_select(
              Task.includes(:client).order(:title).map { |t| task_select_option(t) },
              time_entry.task_id
            ),
            prompt: "Selecione a tarefa" %>
    </div>
    <div><%= f.label :start_time, "Início (data e hora)" %><br><%= f.datetime_local_field :start_time %></div>
    <div><%= f.label :end_time, "Término (data e hora)" %><br><%= f.datetime_local_field :end_time %></div>
    <p class="muted">A duração é calculada automaticamente a partir de início e término.</p>
    <div><%= f.label :description, "Descrição" %><br><%= f.text_area :description, rows: 3 %></div>
  <% end %>

  <div>
    <%= f.submit %>
    <%# PB-013b — Cancelar volta à origem; senão ao detalhe (edição) ou à lista (novo). %>
    <%= link_to "Cancelar", (@return_to.presence || (time_entry.persisted? ? time_entry : time_entries_path)), class: "btn btn--ghost btn--sm" %>
  </div>
<% end %>
