<%= form_with model: project do |f| %>
  <%= hidden_field_tag :return_to, @return_to if @return_to.present? %><%# PB-013b %>
  <% if project.errors.any? %>
    <div class="errors">
      <p><%= pluralize(project.errors.count, "erro") %> impediram salvar:</p>
      <ul>
        <% project.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :client_id, "Cliente" %><br>
    <%= f.collection_select :client_id, Client.order(:name), :id, :name, prompt: "Selecione um cliente" %>
  </div>
  <div><%= f.label :name, "Nome" %><br><%= f.text_field :name %></div>
  <div><%= f.label :description, "Descrição" %><br><%= f.text_area :description, rows: 3 %></div>
  <div><%= f.label :start_date, "Início" %><br><%= f.date_field :start_date %></div>
  <div><%= f.label :end_date, "Término (prazo/fim)" %><br><%= f.date_field :end_date %></div>
  <div>
    <%= f.label :status, "Status" %><br>
    <%= f.select :status, Project::STATUSES.map { |s| [ Project::STATUS_LABELS[s], s ] } %>
  </div>
  <div><%= f.label :budget, "Orçamento (informativo)" %><br><%= f.text_field :budget %></div>

  <div>
    <%= f.submit %>
    <%# PB-013b — Cancelar volta à origem; senão ao detalhe (edição) ou à lista (novo). %>
    <%= link_to "Cancelar", (@return_to.presence || (project.persisted? ? project : projects_path)), class: "btn btn--ghost btn--sm" %>
  </div>
<% end %>
