<% content_for :title, "Projetos" %>

<div class="page-head">
  <div class="page-head__titles"><h1>Projetos</h1></div>
  <div class="page-head__actions">
    <%= link_to "Novo projeto", new_project_path, class: "btn btn--primary" %>
  </div>
</div>

<%# PB-007 — busca + filtros combináveis (GET; preserva via query params). %>
<%= form_with url: projects_path, method: :get, class: "filters" do |f| %>
  <%= f.search_field :q, value: params[:q], placeholder: "Buscar nome ou descrição" %>
  <%= f.select :client_id, options_for_select([ [ "Cliente: todos", "" ] ] + @clients, params[:client_id]) %>
  <%= f.select :status, options_for_select([ [ "Status: todos", "" ] ] + @statuses.map { |s| [ Project::STATUS_LABELS[s], s ] }, params[:status]) %>
  <%= f.select :per_page, options_for_select(per_page_select_options, per_page_selected) %>
  <%= f.submit "Filtrar", class: "btn btn--outline btn--sm" %>
  <%= link_to "Limpar filtros", projects_path, class: "btn btn--ghost btn--sm" %>
<% end %>

<% projects = @projects.to_a %>
<% if projects.any? %>
  <table class="projects-list">
    <thead>
      <tr><th>Projeto</th><th>Cliente</th><th>Status</th><th>Período</th><th>Orçamento</th><th>Ações</th></tr>
    </thead>
    <tbody>
      <% projects.each do |project| %>
        <tr>
          <td class="projects-list__name">
            <%= link_to project.name, project %>
            <% if project.description.present? %>
              <span class="muted projects-list__excerpt"><%= truncate(project.description, length: 80) %></span>
            <% end %>
          </td>
          <td><%= project.client.name %></td>
          <td><%= status_badge(project.status_label) %></td>
          <td><%= [ project.start_date, project.end_date ].compact.map { |d| d.strftime("%d/%m/%Y") }.join(" → ").presence || "—" %></td>
          <td><%= project.budget.presence || "—" %></td>
          <td>
            <%# PB-013b — propaga o contexto da lista. %>
            <div class="te-actions">
              <%= link_to action_icon("eye"), project_path(project, return_to: request.fullpath), class: "btn btn--ghost btn--icon te-action--view",
                    title: "Ver", "aria-label": "Ver projeto" %>
              <%= link_to action_icon("pencil"), edit_project_path(project, return_to: request.fullpath), class: "btn btn--ghost btn--icon te-action--edit",
                    title: "Editar", "aria-label": "Editar projeto" %>
              <%= button_to "Duplicar", duplicate_project_path(project), method: :post,
                    class: "btn btn--ghost btn--sm", form_class: "inline",
                    data: { turbo_confirm: "Duplicar o projeto “#{project.name}”?" } %>
              <%= button_to action_icon("trash"), project_path(project), method: :delete,
                    class: "btn btn--ghost btn--icon te-action--delete", form_class: "inline",
                    params: { return_to: request.fullpath },
                    title: "Excluir", "aria-label": "Excluir projeto",
                    data: { turbo_confirm: "Excluir o projeto “#{project.name}”?" } %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <% if (note = per_page_cap_notice(@total_count)) %><p class="muted pagination__cap-note"><%= note %></p><% end %>
  <%= pagination_nav(current: @page, total_pages: @total_pages, total_count: @total_count, unit: "projeto(s)",
        url: ->(p) { projects_path(request.query_parameters.merge(page: p)) }) %>
<% elsif @filters_active %>
  <div class="empty">
    <p>Nenhum projeto para os filtros atuais.</p>
    <%= link_to "Limpar filtros", projects_path, class: "btn btn--outline btn--sm" %>
  </div>
<% else %>
  <div class="empty">
    <p>Nenhum projeto cadastrado ainda.</p>
    <%= link_to "Novo projeto", new_project_path, class: "btn btn--primary" %>
  </div>
<% end %>
