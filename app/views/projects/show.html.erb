<% content_for :title, @project.name %>

<%# PB-013b — breadcrumb acessível; preserva a origem (lista/busca filtrada). %>
<nav class="breadcrumb" aria-label="Breadcrumb">
  <%= link_to "Projetos", (@return_to.presence || projects_path) %>
  <span class="sep">/</span>
  <span><%= @project.name %></span>
</nav>

<div class="page-head">
  <div class="page-head__titles">
    <h1><%= @project.name %></h1>
    <div class="badge-row">
      <%= configurable_status_badge(Project::STATUS_ENTITY, @project.status) %>
      <span class="muted"><%= @project.client.name %></span>
    </div>
  </div>
  <div class="page-head__actions">
    <%= link_to "Editar", edit_project_path(@project, return_to: @return_to), class: "btn btn--outline btn--sm" %>
    <%= button_to "Excluir", project_path(@project, return_to: @return_to), method: :delete,
          class: "btn btn--ghost btn--sm", form_class: "inline",
          data: { turbo_confirm: "Excluir este projeto?" } %>
  </div>
</div>

<div class="card">
  <dl>
    <dt>Cliente</dt><dd><%= link_to @project.client.name, @project.client %></dd>
    <dt>Status</dt><dd><%= @project.status_label %></dd>
    <dt>Descrição</dt><dd><%= @project.description.presence || "—" %></dd>
    <dt>Início</dt><dd><%= @project.start_date || "—" %></dd>
    <dt>Término</dt><dd><%= @project.end_date || "—" %></dd>
    <dt>Orçamento</dt><dd><%= @project.budget.presence || "—" %></dd>
  </dl>
</div>

<%= link_to "Voltar", (@return_to.presence || projects_path), class: "back-link" %>
