<% content_for :title, (@conversation.title.presence || "Conversa") %>

<nav class="breadcrumb">
  <%= link_to "Conversas", conversations_path %>
  <span class="sep">/</span>
  <span><%= @conversation.title.presence || "— sem título —" %></span>
</nav>

<div class="page-head">
  <div class="page-head__titles">
    <h1><%= @conversation.title.presence || "— sem título —" %></h1>
    <div class="badge-row">
      <%= status_badge(@conversation.source) %>
      <span class="muted">read-only</span>
    </div>
  </div>
</div>

<%# Metadados da conversa. Os turnos (conteúdo) são renderizados mais abaixo
    (read-only, markdown sanitizado — F5.1/F5.2). %>
<div class="card">
  <dl>
    <dt>Thread</dt><dd class="mono"><%= @conversation.thread_id %></dd>
    <dt>Session</dt><dd class="mono"><%= @conversation.session_id || "—" %></dd>
    <dt>Source</dt><dd><%= @conversation.source || "—" %></dd>
    <dt>Título</dt><dd><%= @conversation.title.presence || "—" %></dd>
    <dt>Primeira atividade</dt><dd><%= @conversation.first_ts&.strftime("%d/%m/%Y %H:%M") || "—" %></dd>
    <dt>Última atividade</dt><dd><%= @conversation.last_ts&.strftime("%d/%m/%Y %H:%M") || "—" %></dd>
    <dt>Mensagens</dt><dd><%= @conversation.message_count %></dd>
    <dt>Turnos (user / assistant)</dt><dd><%= @conversation.user_turns %> / <%= @conversation.assistant_turns %></dd>
    <dt>Tool calls</dt><dd><%= @conversation.tool_calls %></dd>
    <dt>Arquivos alterados</dt><dd><%= Array(@conversation.files_changed).join(", ").presence || "—" %></dd>
    <dt>Workspace (hash)</dt><dd class="mono"><%= @conversation.workspace_hash || "—" %></dd>
    <dt>Workspace (folder)</dt><dd><%= @folder.presence || tag.span("— órfão —", class: "muted") %></dd>
    <dt>Pessoal</dt><dd><%= @conversation.personal ? "Sim" : "Não" %></dd>
    <dt>user_id</dt><dd><%= @conversation.user_id || "—" %></dd>
    <dt>Importada</dt><dd><%= @conversation.created_at&.strftime("%d/%m/%Y %H:%M") %></dd>
    <dt>Atualizada</dt><dd><%= @conversation.updated_at&.strftime("%d/%m/%Y %H:%M") %></dd>
  </dl>
</div>

<%# F5.1 — Conversa (turnos read-only via índice de offsets; ADR-021/ADR-012). %>
<% if @turns_hidden_personal %>
  <div class="subhead" id="conversa"><h2>Conversa</h2></div>
  <p class="muted">Esta conversa é <strong>pessoal</strong>. O conteúdo dos turnos está oculto nesta fase (read-only).</p>
<% else %>
  <%= render Conversations::TurnListComponent.new(
        result: @turns, conversation: @conversation, page: @turn_page, total_pages: @turn_total_pages) %>
<% end %>

<%# F4 — Vínculos da conversa (manual). F5.3 — criar tarefa desta conversa. %>
<div class="subhead">
  <h2>Vínculos</h2>
  <% unless @has_primary %>
    <%= link_to "Criar tarefa desta conversa", new_conversation_task_path(@conversation),
          class: "btn btn--outline btn--sm" %>
  <% end %>
</div>

<% if @links.any? %>
  <table>
    <thead>
      <tr><th>Tarefa</th><th>Tipo</th><th>Origem</th><th>Por</th><th>Quando</th><th></th></tr>
    </thead>
    <tbody>
      <% @links.each do |link| %>
        <tr>
          <td><%= link_to link.task.title, link.task %> <span class="muted">(<%= link.task.client.name %>)</span></td>
          <td><%= tag.span(link.link_type, class: "badge badge--#{link.link_type == 'primary' ? 'info' : 'neutral'}") %></td>
          <td><%= link.origin %></td>
          <td><%= link.created_by&.username || "—" %></td>
          <td><%= link.created_at&.strftime("%d/%m/%Y %H:%M") %></td>
          <td><%= button_to "Remover", conversation_link_path(@conversation, link), method: :delete,
                    form_class: "inline", class: "btn btn--ghost btn--sm",
                    data: { turbo_confirm: "Remover este vínculo?" } %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="muted">Nenhuma tarefa vinculada a esta conversa ainda.</p>
<% end %>

<div class="card form-card">
  <%= form_with url: conversation_links_path(@conversation), method: :post do |f| %>
    <div>
      <%= label_tag :task_id, "Tarefa" %><br>
      <%= select_tag :task_id,
            options_for_select(@tasks.map { |t| [ "#{t.title} (#{t.client.name})", t.id ] }),
            prompt: "Selecione a tarefa" %>
    </div>
    <div>
      <%= label_tag :link_type, "Tipo de vínculo" %><br>
      <%= select_tag :link_type, options_for_select([ [ "Primário", "primary" ], [ "Menção", "mention" ] ], "primary") %>
    </div>
    <% if @has_primary %>
      <p class="muted">Já existe um vínculo <strong>primário</strong> nesta conversa — use “Menção” ou remova o primário atual antes.</p>
    <% end %>
    <div><%= submit_tag "Vincular tarefa", class: "btn btn--primary" %></div>
  <% end %>
</div>

<%= link_to "Voltar", conversations_path, class: "back-link" %>
