<%# PB-020 (Triagem) — modo triagem da conversa. Tela dividida: turnos à esquerda
    (reusa TurnListComponent), análise/evidências à direita. A decisão de triagem
    (Aberta/Revisada/Ignorada) e a confirmação de cliente são persistidas aqui;
    cliente sem confirmação fica como sugestão; gaps são só visuais; sem TimeEntry. %>

<nav class="breadcrumb" aria-label="Breadcrumb">
  <%= link_to "Triagem", triage_path %>
  <span class="sep">/</span>
  <span><%= @conversation.title.presence || "— sem título —" %></span>
</nav>

<div class="page-head">
  <div class="page-head__titles">
    <h1><%= @conversation.title.presence || "— sem título —" %></h1>
    <div class="badge-row">
      <%= status_badge(@conversation.source) %>
      <span class="badge badge--neutral"><%= @triage.label %></span>
      <span class="muted mono">
        📁 <%= @folder.presence || (@conversation.workspace_hash.present? ? "#{@conversation.workspace_hash.truncate(12)} (órfão)" : "—") %>
        · <%= local_datetime(@conversation.first_ts) %> → <%= local_datetime(@conversation.last_ts) %>
        · <%= @conversation.message_count %> msgs · <%= @conversation.tool_calls %> tool calls
      </span>
    </div>
  </div>
</div>

<div class="triage-detail">
  <%# ── ESQUERDA · timeline/turnos ── %>
  <section class="triage-detail__timeline">
    <div class="subhead">
      <h2 id="conversa">Timeline da conversa</h2>
      <span class="muted">evidência · não relógio absoluto</span>
    </div>
    <% if @turns_hidden_personal %>
      <p class="muted">Esta conversa é <strong>pessoal</strong>. O conteúdo dos turnos está oculto nesta fase (somente leitura).</p>
    <% else %>
      <%= render Conversations::TurnListComponent.new(
            result: @turns, conversation: @conversation, page: @turn_page, total_pages: @turn_total_pages,
            per_page: @turn_per_page, per_page_options: ConversationsController::TURNS_PER_PAGE_OPTIONS) %>
    <% end %>
  </section>

  <%# ── DIREITA · análise extraída (somente leitura, exceto a decisão de triagem) ── %>
  <aside class="triage-detail__panel">
    <%# Decisão de triagem (estado persistido): Aberta / Revisada / Ignorada. %>
    <div class="card">
      <div class="suggest-block__head">
        <h2>Decisão de triagem</h2>
        <span class="badge badge--neutral"><%= @triage.label %></span>
      </div>
      <p class="muted">
        <% if @triage.persisted? %>Decisão registrada: <strong><%= @triage.persisted_status_label %></strong>.
        <% else %>Sem decisão registrada (estado derivado).<% end %>
      </p>
      <div class="triage-actions">
        <% if @triage.persisted_status != "reviewed" %>
          <%= button_to "Marcar revisada", conversation_triage_path(@conversation, status: "reviewed", return_to: request.fullpath),
                method: :patch, class: "btn btn--outline btn--sm", form_class: "inline" %>
        <% end %>
        <% if @triage.persisted_status != "ignored" %>
          <%= button_to "Ignorar", conversation_triage_path(@conversation, status: "ignored", return_to: request.fullpath),
                method: :patch, class: "btn btn--ghost btn--sm", form_class: "inline" %>
        <% end %>
        <% if @triage.persisted? && @triage.persisted_status != "open" %>
          <%= button_to "Reabrir", conversation_triage_path(@conversation, status: "open", return_to: request.fullpath),
                method: :patch, class: "btn btn--outline btn--sm", form_class: "inline" %>
        <% end %>
      </div>
    </div>

    <%# Cliente confirmado (decisão humana) × sugerido (workspace). Confirmação ≠ tarefa. %>
    <div class="card suggest-block">
      <div class="suggest-block__head">
        <h2>Cliente</h2>
        <% if @triage.client_confirmed? %>
          <span class="badge badge--success">confirmado</span>
        <% else %>
          <span class="badge badge--neutral">sugestão</span>
        <% end %>
      </div>
      <% if @triage.client_confirmed? %>
        <p><strong><%= @triage.client.name %></strong></p>
      <% elsif @triage.client %>
        <p><strong><%= @triage.client.name %></strong> <span class="muted">(sugerido pelo workspace — confirmar)</span></p>
        <p class="muted">via workspace → <span class="mono"><%= @triage.folder %></span> → clients.workspace_paths</p>
      <% else %>
        <p class="muted">Sem cliente sugerível pelo workspace. Confirme manualmente abaixo.</p>
      <% end %>

      <%# Confirmar cliente SEM criar tarefa (decisão de vínculo comercial/operacional). %>
      <%= form_with url: conversation_triage_path(@conversation), method: :patch, class: "triage-confirm" do |f| %>
        <%= hidden_field_tag :return_to, request.fullpath %>
        <%= label_tag :confirmed_client_id, "Confirmar cliente" %>
        <%= select_tag :confirmed_client_id,
              options_for_select(@clients.map { |c| [ c.name, c.id ] }, @triage.client&.id),
              include_blank: "— nenhum —" %>
        <%= submit_tag "Confirmar cliente", class: "btn btn--primary btn--sm" %>
      <% end %>
    </div>

    <%# Evidências reais da conversa. %>
    <div class="card">
      <div class="subhead"><h2>Evidências</h2></div>
      <dl class="suggest-kv">
        <dt>Workspace</dt><dd class="mono"><%= @folder.presence || "—" %></dd>
        <dt>Hash</dt><dd class="mono"><%= @conversation.workspace_hash.presence || "—" %></dd>
        <dt>Período</dt><dd><%= local_datetime(@conversation.first_ts) %> → <%= local_datetime(@conversation.last_ts) %></dd>
        <dt>Turnos (user / assistant)</dt><dd><%= @conversation.user_turns %> / <%= @conversation.assistant_turns %></dd>
        <dt>Tool calls</dt><dd><%= @conversation.tool_calls %></dd>
        <dt>Arquivos alterados</dt><dd><%= Array(@conversation.files_changed).join(", ").presence || "—" %></dd>
      </dl>
    </div>

    <%# Gaps detectados (apenas visuais; sem classificação nesta fatia). %>
    <div class="card">
      <div class="subhead">
        <h2>Gaps detectados</h2>
        <span class="muted">&gt; 15 min entre turnos</span>
      </div>
      <% if @timeline.any_gaps? %>
        <ul class="triage-gaps">
          <% @timeline.gaps.each do |gap| %>
            <li class="triage-gaps__item">
              <span class="triage-gaps__dur mono">⊟ <%= duration_label(gap.seconds) %></span>
              <span class="muted">após turno <%= gap.after_line_no %> · <%= local_time(gap.from_ts) %> → <%= local_time(gap.to_ts) %></span>
            </li>
          <% end %>
        </ul>
        <p class="muted triage-gaps__note">Gaps são evidência, não pausa automática. Classificação e apuração de tempo entram em fatia futura.</p>
      <% else %>
        <p class="muted">Nenhum gap relevante (&gt; 15 min) entre os turnos com horário registrado.</p>
      <% end %>
    </div>

    <%# Atividades de 2º nível (rascunhos manuais da conversa). PB-020. %>
    <%= render "conversations/activity_drafts",
          conversation: @conversation, drafts: @activity_drafts, new_draft: @new_activity_draft,
          has_primary: @has_primary, primary_link: @links.find { |l| l.link_type == "primary" } %>

    <%# Blocos de trabalho (rascunhos por turno/dia). PB-020d — sem promover a TimeEntry. %>
    <%= render "conversations/work_blocks",
          conversation: @conversation, blocks: @work_blocks, new_block: @new_work_block %>

    <%# Ações conforme o estado real do vínculo (fonte: ConversationLink). %>
    <div class="card">
      <div class="subhead"><h2>Tarefa</h2></div>
      <% primary_link = @links.find { |l| l.link_type == "primary" } %>
      <% if primary_link %>
        <%# Já vinculada: mostra a tarefa e oferece abrir — não sugere criar do zero. %>
        <p>
          Vinculada a <%= link_to task_code_label(primary_link.task), primary_link.task %>
          <span class="muted">(<%= primary_link.task.client.name %>)</span>.
        </p>
        <div class="triage-detail__cta">
          <%= link_to "Abrir tarefa", primary_link.task, class: "btn btn--primary btn--sm" %>
        </div>
      <% else %>
        <%# Não vinculada: criar tarefa (com cliente/projeto CONFIRMADO, se houver) ou vincular a existente. %>
        <p class="muted">
          Esta conversa ainda não tem tarefa primária.
          <% if @triage.client_confirmed? %>
            A tarefa nascerá com o cliente confirmado <strong><%= @triage.client.name %></strong><% if @triage.confirmed_project %> e o projeto <strong><%= @triage.confirmed_project.name %></strong><% end %>.
          <% elsif @triage.client %>
            Há um cliente <em>sugerido</em> (<%= @triage.client.name %>) — confirme acima para usá-lo na tarefa.
          <% end %>
        </p>
        <div class="triage-detail__cta">
          <%= link_to "Criar tarefa desta conversa",
                new_conversation_task_path(@conversation,
                  client_id: @triage.client_confirmed? ? @triage.client&.id : nil,
                  project_id: @triage.confirmed_project&.id,
                  return_to: request.fullpath),
                class: "btn btn--primary" %>
          <%= link_to "Vincular a tarefa existente", "#vincular-tarefa", class: "btn btn--outline btn--sm" %>
        </div>
      <% end %>
    </div>

    <div class="triage-detail__cta">
      <%= link_to "Voltar", (@return_to.presence || triage_path), class: "btn btn--outline btn--sm" %>
    </div>
  </aside>
</div>

<%# Vínculos da conversa (fonte: ConversationLink — mesma seção do show normal). %>
<div class="subhead" id="vincular-tarefa"><h2>Vínculos</h2></div>
<% if @links.any? %>
  <table>
    <thead>
      <tr><th>Tarefa</th><th>Tipo</th><th>Origem</th><th>Por</th><th>Quando</th><th></th></tr>
    </thead>
    <tbody>
      <% @links.each do |link| %>
        <tr>
          <td><%= link_to task_code_label(link.task), link.task %> <span class="muted">(<%= link.task.client.name %>)</span></td>
          <td><%= tag.span(link.link_type, class: "badge badge--#{link.link_type == 'primary' ? 'info' : 'neutral'}") %></td>
          <td><%= link.origin %></td>
          <td><%= link.created_by&.username || "—" %></td>
          <td><%= link.created_at&.strftime("%d/%m/%Y %H:%M") %></td>
          <td><%= button_to "Remover", conversation_link_path(@conversation, link), method: :delete,
                    form_class: "inline", class: "btn btn--ghost btn--sm",
                    data: { turbo_confirm: "Remover este vínculo?" } %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="muted">Nenhuma tarefa vinculada a esta conversa ainda.</p>
<% end %>

<div class="card form-card">
  <%= form_with url: conversation_links_path(@conversation), method: :post do |f| %>
    <div>
      <%= label_tag :task_id, "Tarefa" %><br>
      <%= select_tag :task_id, options_for_select(@tasks.map { |t| task_select_option(t) }), prompt: "Selecione a tarefa" %>
    </div>
    <div>
      <%= label_tag :link_type, "Tipo de vínculo" %><br>
      <%= select_tag :link_type, options_for_select([ [ "Primário", "primary" ], [ "Menção", "mention" ] ], "primary") %>
    </div>
    <% if @has_primary %>
      <p class="muted">Já existe um vínculo <strong>primário</strong> nesta conversa — use “Menção” ou remova o primário atual antes.</p>
    <% end %>
    <div><%= submit_tag "Vincular tarefa", class: "btn btn--primary" %></div>
  <% end %>
</div>
