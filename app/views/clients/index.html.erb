<% content_for :title, "Clientes" %>

<div class="page-head">
  <div class="page-head__titles"><h1>Clientes</h1></div>
  <div class="page-head__actions">
    <%= link_to "Novo cliente", new_client_path, class: "btn btn--primary" %>
  </div>
</div>

<% if @clients.any? %>
  <table>
    <thead>
      <tr><th>Nome</th><th>CNPJ</th><th>Status</th><th>Ações</th></tr>
    </thead>
    <tbody>
      <% @clients.each do |client| %>
        <tr>
          <td><%= link_to client.name, client %></td>
          <td><%= client.cnpj || "—" %></td>
          <td><%= status_badge(client.status) %></td>
          <td><%= link_to "Editar", edit_client_path(client), class: "btn btn--ghost btn--sm" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="empty">
    <p>Nenhum cliente ainda.</p>
    <%= link_to "Novo cliente", new_client_path, class: "btn btn--primary" %>
  </div>
<% end %>
