<%# PB-006 — data-controller habilita o autopreenchimento por CNPJ. A consulta vai
    direto do navegador para a BrasilAPI (IP do usuário; ADR-022 addendum 2026-06-22);
    sem JS, o form continua funcionando (digitação manual). %>
<%= form_with model: client, data: { controller: "cnpj-lookup" } do |f| %>
  <%= hidden_field_tag :return_to, @return_to if @return_to.present? %><%# PB-013b %>
  <% if client.errors.any? %>
    <div class="errors">
      <p><%= pluralize(client.errors.count, "erro") %> impediram salvar:</p>
      <ul>
        <% client.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :cnpj, "CNPJ" %><br>
    <%= f.text_field :cnpj, data: { "cnpj-lookup-target": "cnpj" } %>
    <button type="button" class="btn btn--outline btn--sm" data-action="cnpj-lookup#lookup">Buscar dados do CNPJ</button>
    <span class="muted" data-cnpj-lookup-target="status" aria-live="polite"></span>
  </div>
  <div><%= f.label :name, "Nome / Razão social" %><br><%= f.text_field :name, data: { "cnpj-lookup-target": "name" } %></div>
  <div><%= f.label :trade_name, "Nome fantasia" %><br><%= f.text_field :trade_name, data: { "cnpj-lookup-target": "tradeName" } %></div>
  <div><%= f.label :phone, "Telefone" %><br><%= f.text_field :phone, data: { "cnpj-lookup-target": "phone" } %></div>
  <div><%= f.label :address, "Endereço" %><br><%= f.text_field :address, data: { "cnpj-lookup-target": "address" } %></div>
  <div><%= f.label :status, "Status" %><br><%= f.text_field :status, data: { "cnpj-lookup-target": "status" } %></div>
  <div>
    <%= f.label :workspace_paths_text, "Workspace paths (uma pasta por linha)" %><br>
    <%= f.text_area :workspace_paths_text, rows: 4 %>
  </div>

  <div>
    <%= f.submit %>
    <%# PB-013b — Cancelar volta à origem; senão ao detalhe (edição) ou à lista (novo). %>
    <%= link_to "Cancelar", (@return_to.presence || (client.persisted? ? client : clients_path)), class: "btn btn--ghost btn--sm" %>
  </div>
<% end %>
