<% content_for :title, @client.name %>

<%# PB-013b — breadcrumb acessível; preserva a origem (aba/filtros/página). %>
<nav class="breadcrumb" aria-label="Breadcrumb">
  <%= link_to "Clientes", (@return_to.presence || clients_path) %>
  <span class="sep">/</span>
  <span><%= @client.name %></span>
</nav>

<div class="page-head">
  <div class="page-head__titles">
    <h1><%= @client.name %></h1>
    <div class="badge-row"><%= status_badge(@client.status) %></div>
  </div>
  <div class="page-head__actions">
    <%= link_to "Editar", edit_client_path(@client, return_to: @return_to), class: "btn btn--outline btn--sm" %>
    <%= button_to "Excluir", client_path(@client, return_to: @return_to), method: :delete,
          class: "btn btn--ghost btn--sm", form_class: "inline",
          data: { turbo_confirm: "Excluir este cliente?" } %>
  </div>
</div>

<div class="card">
  <dl>
    <dt>Nome fantasia</dt><dd><%= @client.trade_name || "—" %></dd>
    <dt>CNPJ</dt><dd><%= @client.cnpj || "—" %></dd>
    <dt>Telefone</dt><dd><%= @client.phone || "—" %></dd>
    <dt>Endereço</dt><dd><%= @client.address || "—" %></dd>
    <dt>Status</dt><dd><%= @client.status %></dd>
    <dt>Workspace paths</dt><dd><%= @client.workspace_paths.join(", ").presence || "—" %></dd>
  </dl>
</div>

<div class="subhead">
  <h2>Contatos</h2>
  <%# PB-013b — contato aberto pelo cliente retorna ao próprio cliente. %>
  <%= link_to "Novo contato", new_client_contact_path(@client, return_to: request.fullpath), class: "btn btn--outline btn--sm" %>
</div>

<% if @client.contacts.any? %>
  <ul class="contacts">
    <% @client.contacts.order(:name).each do |contact| %>
      <li>
        <strong><%= contact.name %></strong>
        <span class="muted">&lt;<%= contact.email %>&gt;</span>
        <% if contact.is_primary %><span class="badge badge--info">★ primário</span><% end %>
        <span class="contact-actions actions">
          <%= link_to "Editar", edit_client_contact_path(@client, contact, return_to: request.fullpath) %>
          <span class="sep">·</span>
          <%= button_to "Excluir", client_contact_path(@client, contact), method: :delete,
                class: "btn btn--ghost btn--sm", form_class: "inline", params: { return_to: request.fullpath },
                data: { turbo_confirm: "Excluir contato?" } %>
        </span>
      </li>
    <% end %>
  </ul>
<% else %>
  <div class="empty">
    <p>Nenhum contato.</p>
    <%= link_to "Novo contato", new_client_contact_path(@client, return_to: request.fullpath), class: "btn btn--outline btn--sm" %>
  </div>
<% end %>

<%= link_to "Voltar", (@return_to.presence || clients_path), class: "back-link" %>
