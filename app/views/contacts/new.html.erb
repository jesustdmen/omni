<% content_for :title, "Novo contato" %>

<%# PB-013b — breadcrumb acessível; "Clientes" preserva a origem (cliente ou aba global Contatos). %>
<nav class="breadcrumb" aria-label="Breadcrumb">
  <%= link_to "Clientes", (@return_to.presence || clients_path) %>
  <span class="sep">/</span>
  <%= link_to @client.name, @client %>
  <span class="sep">/</span>
  <span>Novo contato</span>
</nav>

<div class="page-head"><div class="page-head__titles"><h1>Novo contato — <%= @client.name %></h1></div></div>

<div class="card form-card"><%= render "form", client: @client, contact: @contact %></div>

<%= link_to "Voltar", (@return_to.presence || @client), class: "back-link" %>
