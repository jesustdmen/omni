<%= form_with model: [client, contact] do |f| %>
  <% if contact.errors.any? %>
    <div class="errors">
      <p><%= pluralize(contact.errors.count, "erro") %> impediram salvar:</p>
      <ul>
        <% contact.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div><%= f.label :name, "Nome" %><br><%= f.text_field :name %></div>
  <div><%= f.label :email, "E-mail" %><br><%= f.text_field :email %></div>
  <div><%= f.label :phone, "Telefone" %><br><%= f.text_field :phone %></div>
  <div><%= f.label :position, "Cargo" %><br><%= f.text_field :position %></div>
  <div><%= f.label :is_primary, "Contato primário" %> <%= f.check_box :is_primary %></div>

  <div><%= f.submit %></div>
<% end %>
