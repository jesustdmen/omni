<% content_for :title, "Tarefas" %>

<div class="page-head">
  <div class="page-head__titles"><h1>Tarefas</h1></div>
  <div class="page-head__actions">
    <%= link_to "Nova tarefa", new_task_path, class: "btn btn--primary" %>
  </div>
</div>

<%# PB-004a — busca + filtros combináveis (GET; preserva via query params). %>
<%= form_with url: tasks_path, method: :get, class: "filters" do |f| %>
  <%= f.search_field :q, value: params[:q], placeholder: "Buscar título ou descrição" %>
  <%= f.select :status, options_for_select([ [ "Status: todos", "" ] ] + @statuses.map { |s| [ s.humanize, s ] }, params[:status]) %>
  <%= f.select :type, options_for_select([ [ "Tipo: todos", "" ] ] + @types.map { |t| [ t.humanize, t ] }, params[:type]) %>
  <%= f.select :client_id, options_for_select([ [ "Cliente: todos", "" ] ] + @clients, params[:client_id]) %>
  <%= f.select :per_page, options_for_select(TasksController::PER_PAGE_OPTIONS.map { |n| [ "#{n}/página", n ] }, @per_page) %>
  <%= f.submit "Filtrar", class: "btn btn--outline btn--sm" %>
  <%= link_to "Limpar filtros", tasks_path, class: "btn btn--ghost btn--sm" %>
<% end %>

<%# PB-004a — carrega a página 1x (any?/each operam sobre o array; sem query EXISTS extra). %>
<% tasks = @tasks.to_a %>
<% if tasks.any? %>
  <table class="tasks-list">
    <thead>
      <tr><th>Tarefa</th><th>Cliente</th><th>Projeto</th><th>Status</th><th>Tipo</th><th>Criada em</th><th>Ações</th></tr>
    </thead>
    <tbody>
      <% tasks.each do |task| %>
        <tr>
          <td class="tasks-list__title">
            <%= link_to task.title, task %>
            <% if task.description.present? %>
              <span class="muted tasks-list__excerpt"><%= truncate(task.description, length: 80) %></span>
            <% end %>
          </td>
          <td><%= task.client.name %></td>
          <td><%= task.project&.name || "—" %></td>
          <td><%= status_badge(task.status) %></td>
          <td><%= status_badge(task.type) %></td>
          <td><%= task.created_at.strftime("%d/%m/%Y") %></td>
          <td>
            <%# PB-013b — leva o contexto da lista (busca/filtros/paginação) p/ detalhe/edição/exclusão. %>
            <div class="te-actions">
              <%= link_to action_icon("eye"), task_path(task, return_to: request.fullpath), class: "btn btn--ghost btn--icon te-action--view",
                    title: "Ver", "aria-label": "Ver tarefa" %>
              <%= link_to action_icon("pencil"), edit_task_path(task, return_to: request.fullpath), class: "btn btn--ghost btn--icon te-action--edit",
                    title: "Editar", "aria-label": "Editar tarefa" %>
              <%= button_to action_icon("trash"), task_path(task), method: :delete,
                    class: "btn btn--ghost btn--icon te-action--delete", form_class: "inline",
                    params: { return_to: request.fullpath },
                    title: "Excluir", "aria-label": "Excluir tarefa",
                    data: { turbo_confirm: "Excluir a tarefa “#{task.title}”?" } %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div class="pagination">
    <span class="muted"><%= @total_count %> tarefa(s) · página <%= @page %>/<%= @total_pages %></span>
    <span class="actions">
      <% if @page > 1 %><%= link_to "← Anterior", tasks_path(request.query_parameters.merge(page: @page - 1)), class: "btn btn--ghost btn--sm" %><% end %>
      <% if @page < @total_pages %><%= link_to "Próxima →", tasks_path(request.query_parameters.merge(page: @page + 1)), class: "btn btn--ghost btn--sm" %><% end %>
    </span>
  </div>
<% elsif @filters_active %>
  <div class="empty">
    <p>Nenhuma tarefa para os filtros atuais.</p>
    <%= link_to "Limpar filtros", tasks_path, class: "btn btn--outline btn--sm" %>
  </div>
<% else %>
  <div class="empty">
    <p>Nenhuma tarefa cadastrada ainda.</p>
    <%= link_to "Nova tarefa", new_task_path, class: "btn btn--primary" %>
  </div>
<% end %>
