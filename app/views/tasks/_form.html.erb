<%# `url` opcional: quando ausente, form_with infere a rota do model (/tasks). %>
<%= form_with model: task, url: local_assigns[:url] do |f| %>
  <%# PB-013b — preserva a origem através do submit (Salvar honra; erro mantém). %>
  <%= hidden_field_tag :return_to, @return_to if @return_to.present? %>
  <% if task.errors.any? %>
    <div class="errors">
      <p><%= pluralize(task.errors.count, "erro") %> impediram salvar:</p>
      <ul>
        <% task.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :client_id, "Cliente" %><br>
    <%= f.collection_select :client_id, Client.order(:name), :id, :name, prompt: "Selecione um cliente" %>
  </div>
  <div>
    <%= f.label :project_id, "Projeto (opcional)" %><br>
    <%= f.select :project_id,
          options_for_select(
            Project.includes(:client).order(:name).map { |p| ["#{p.name} (#{p.client.name})", p.id] },
            task.project_id
          ),
          include_blank: "— sem projeto —" %>
  </div>
  <div><%= f.label :title, "Título" %><br><%= f.text_field :title %></div>
  <div>
    <%= f.label :type, "Tipo" %><br>
    <%= f.select :type, options_for_select(Task::TYPES.map { |t| [Task.type_label(t), t] }, task.type), prompt: "Selecione o tipo" %>
  </div>
  <div>
    <%= f.label :status, "Status" %><br>
    <%# PB-018 — opções de status configuráveis (ativos + o atual do registro). %>
    <%= f.select :status, options_for_select(ConfigurableStatus.select_options(Task::STATUS_ENTITY, current_key: task.status), task.status) %>
  </div>
  <div><%= f.label :description, "Descrição" %><br><%= f.text_area :description, rows: 3 %></div>

  <div>
    <%= f.submit %>
    <%# PB-013b — Cancelar volta à origem (lista filtrada/detalhe); senão à lista. %>
    <%= link_to "Cancelar", (@return_to.presence || (task.persisted? ? task : tasks_path)), class: "btn btn--ghost btn--sm" %>
  </div>
<% end %>
