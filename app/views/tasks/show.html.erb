<% content_for :title, @task.title %>

<nav class="breadcrumb">
  <%= link_to "Tarefas", tasks_path %>
  <span class="sep">/</span>
  <span><%= @task.title %></span>
</nav>

<div class="page-head">
  <div class="page-head__titles">
    <h1><%= @task.title %></h1>
    <div class="badge-row">
      <%= status_badge(@task.status) %>
      <%= status_badge(@task.type) %>
      <span class="muted"><%= @task.client.name %></span>
    </div>
  </div>
  <div class="page-head__actions">
    <%= link_to "Editar", edit_task_path(@task), class: "btn btn--outline btn--sm" %>
    <%= link_to "Excluir", @task,
          data: { turbo_method: :delete, turbo_confirm: "Excluir tarefa?" },
          class: "btn btn--ghost btn--sm" %>
  </div>
</div>

<%# Abas: "Detalhes" e "Time entries" têm conteúdo real; as demais são placeholders
    intencionais (sinalizadas "em breve") até a Fase 5+. Sem troca dinâmica nesta fase. %>
<nav class="tabs">
  <span class="tab active">Detalhes</span>
  <span class="tab soon">Conversas<span class="soon-flag">em breve</span></span>
  <span class="tab">Time entries</span>
  <span class="tab soon">Histórico<span class="soon-flag">em breve</span></span>
  <span class="tab soon">Demanda<span class="soon-flag">em breve</span></span>
</nav>

<section class="tab-panel" id="tab-detalhes">
  <div class="card">
    <dl>
      <dt>Título</dt><dd><%= @task.title %></dd>
      <dt>Tipo</dt><dd><%= @task.type %></dd>
      <dt>Status</dt><dd><%= @task.status %></dd>
      <dt>Cliente</dt><dd><%= link_to @task.client.name, @task.client %></dd>
      <dt>Projeto</dt><dd><%= @task.project ? link_to(@task.project.name, @task.project) : "—" %></dd>
      <dt>Descrição</dt><dd><%= @task.description.presence || "—" %></dd>
      <dt>Conversas</dt><dd><%= @task.conversation_count %></dd>
      <dt>Última conversa</dt><dd><%= @task.last_conversation_at || "—" %></dd>
    </dl>
  </div>
</section>

<%# Aba "Time entries" — conteúdo real read-only (F2.5). CRUD completo vive em /time_entries. %>
<section class="tab-panel" id="tab-time">
  <div class="subhead">
    <h2>Time entries</h2>
    <%= link_to "Novo apontamento", new_time_entry_path(task_id: @task.id), class: "btn btn--outline btn--sm" %>
  </div>

  <% entries = @task.time_entries.order(start_time: :desc) %>
  <% if entries.any? %>
    <table>
      <thead>
        <tr><th>Data</th><th>Início</th><th>Duração</th><th>Descrição</th><th>Ações</th></tr>
      </thead>
      <tbody>
        <% entries.each do |entry| %>
          <tr>
            <td><%= entry.date %></td>
            <td><%= entry.start_time&.strftime("%d/%m/%Y %H:%M") %></td>
            <td><%= duration_label(entry.duration) %></td>
            <td><%= entry.description.presence || "—" %></td>
            <td><%= link_to "Ver", entry, class: "btn btn--ghost btn--sm" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <p class="te-total">Total de duração: <strong><%= duration_label(@task.total_duration) %></strong></p>
  <% else %>
    <div class="empty">
      <p>Nenhum apontamento nesta tarefa.</p>
      <%= link_to "Novo apontamento", new_time_entry_path(task_id: @task.id), class: "btn btn--outline btn--sm" %>
    </div>
  <% end %>
</section>

<section class="tab-panel placeholder" id="tab-conversas">
  Conversas vinculadas aparecerão aqui em fase futura.
</section>
<section class="tab-panel placeholder" id="tab-historico">
  Histórico operacional será exibido aqui em fase futura.
</section>
<section class="tab-panel placeholder" id="tab-demanda">
  Dados da demanda relacionada aparecerão aqui quando aplicável.
</section>

<p><%= link_to "Voltar", tasks_path, class: "back-link" %></p>
