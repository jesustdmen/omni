<% content_for :title, @task.title %>

<%# PB-013b — breadcrumb acessível; "Tarefas" preserva a origem (lista/busca filtrada). %>
<nav class="breadcrumb" aria-label="Breadcrumb">
  <%= link_to "Tarefas", (@return_to.presence || tasks_path) %>
  <span class="sep">/</span>
  <span><%= @task.title %></span>
</nav>

<div class="page-head">
  <div class="page-head__titles">
    <h1><%= @task.title %></h1>
    <div class="badge-row">
      <%= status_badge(@task.status) %>
      <%= status_badge(@task.type) %>
      <span class="muted"><%= @task.client.name %></span>
    </div>
  </div>
  <div class="page-head__actions">
    <%# PB-013b — Editar propaga o contexto; Excluir retorna à origem após sucesso. %>
    <%= link_to "Editar", edit_task_path(@task, return_to: @return_to), class: "btn btn--outline btn--sm" %>
    <%= button_to "Excluir", task_path(@task, return_to: @return_to), method: :delete,
          class: "btn btn--ghost btn--sm", form_class: "inline",
          data: { turbo_confirm: "Excluir tarefa?" } %>
  </div>
</div>

<%# F5.5 — navegação HONESTA por âncoras (sem JS): os itens reais são links que
    rolam até a seção (todos os painéis ficam visíveis/empilhados). "Histórico" e
    "Demanda" são placeholders "em breve" — sem href, não parecem ação. %>
<nav class="tabs">
  <%= link_to "Detalhes", "#tab-detalhes", class: "tab" %>
  <%= link_to "#tab-conversas", class: "tab" do %>
    Conversas<% if @linked_conversations.any? %> <span class="tab__count">(<%= @linked_conversations.size %>)</span><% end %>
  <% end %>
  <%= link_to "Time entries", "#tab-time", class: "tab" %>
  <span class="tab soon" aria-disabled="true">Histórico<span class="soon-flag">em breve</span></span>
  <%= link_to "#tab-demanda", class: "tab" do %>
    Demanda<% if @origin_demand %> <span class="tab__count">(1)</span><% end %>
  <% end %>
</nav>

<section class="tab-panel" id="tab-detalhes">
  <div class="card">
    <dl>
      <dt>Título</dt><dd><%= @task.title %></dd>
      <dt>Tipo</dt><dd><%= @task.type %></dd>
      <dt>Status</dt><dd><%= @task.status %></dd>
      <dt>Cliente</dt><dd><%= link_to @task.client.name, @task.client %></dd>
      <dt>Projeto</dt><dd><%= @task.project ? link_to(@task.project.name, @task.project) : "—" %></dd>
      <dt>Descrição</dt><dd><%= @task.description.presence || "—" %></dd>
      <dt>Conversas</dt><dd><%= @task.conversation_count %></dd>
      <dt>Última conversa</dt><dd><%= @task.last_conversation_at || "—" %></dd>
    </dl>
  </div>

  <%# PB-004b — checklist persistente da tarefa (sem JS; Turbo é melhoria progressiva). %>
  <% done = @checklist_items.count(&:completed) %>
  <div class="card checklist">
    <div class="subhead">
      <div class="subhead__titles">
        <h2>Checklist</h2>
        <p class="muted"><%= done %>/<%= @checklist_items.size %> concluído(s)</p>
      </div>
    </div>

    <% if @checklist_items.any? %>
      <ul class="checklist__list">
        <% @checklist_items.each do |item| %>
          <%# Linha = flex de 3 partes que NÃO se movem: [✓ toggle] [conteúdo/edição] [🗑].
              O miolo é um <details> (nativo, sem JS): summary = texto (modo exibição);
              aberto = input no mesmo lugar (modo edição), mantendo a linha estável. %>
          <li class="checklist__item <%= 'checklist__item--done' if item.completed %>">
            <%= button_to task_checklist_item_path(@task, item),
                  method: :patch, params: { checklist_item: { completed: !item.completed } },
                  class: "btn btn--ghost btn--icon checklist__toggle", form_class: "inline",
                  title: (item.completed ? "Reabrir item" : "Concluir item"),
                  "aria-label": (item.completed ? "Reabrir item" : "Concluir item") do %>
              <%= item.completed ? "☑" : "☐" %>
            <% end %>

            <details class="checklist__row">
              <summary class="checklist__display">
                <span class="checklist__content"><%= item.content %></span>
                <span class="btn btn--ghost btn--icon te-action--edit checklist__edit-affordance"
                      title="Editar item" aria-label="Editar item"><%= action_icon("pencil") %></span>
              </summary>
              <%= form_with model: item, url: task_checklist_item_path(@task, item), method: :patch, class: "checklist__edit" do |f| %>
                <%= f.text_field :content, "aria-label": "Editar texto do item" %>
                <%= f.submit "Salvar", class: "btn btn--primary btn--sm" %>
                <%# "Cancelar" = volta para a tarefa (fecha a edição sem salvar). %>
                <%= link_to "Cancelar", task_path(@task, anchor: "tab-detalhes"), class: "btn btn--ghost btn--sm" %>
              <% end %>
            </details>

            <%= button_to action_icon("trash"), task_checklist_item_path(@task, item),
                  method: :delete, class: "btn btn--ghost btn--icon te-action--delete", form_class: "inline",
                  title: "Excluir item", "aria-label": "Excluir item",
                  data: { turbo_confirm: "Excluir este item do checklist?" } %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="muted">Nenhum item no checklist ainda.</p>
    <% end %>

    <%# adicionar item — formulário sempre visível. %>
    <%= form_with model: @checklist_item, url: task_checklist_items_path(@task), class: "checklist__add" do |f| %>
      <%= f.text_field :content, placeholder: "Novo item do checklist", "aria-label": "Novo item do checklist" %>
      <%= f.submit "Adicionar", class: "btn btn--outline btn--sm" %>
    <% end %>
  </div>
</section>

<%# PB-003a — Histórico de Apontamentos (timer + registro de tempo). %>
<section class="tab-panel" id="tab-time">
  <%# PB-003b — carrega 1x e agrupa em memória (sem consulta por grupo/linha). %>
  <% entries = @task.time_entries.order(start_time: :desc).to_a %>
  <div class="subhead">
    <div class="subhead__titles">
      <h2>Histórico de Apontamentos</h2>
      <p class="muted"><%= entries.size %> apontamento(s) registrado(s)</p>
    </div>
    <div class="page-head__actions">
      <%# Controle de timer da tarefa (1 aberto por tarefa). %>
      <% running = entries.find(&:is_running) %>
      <% if running %>
        <span class="muted">⏱ em andamento desde <%= running.start_time&.strftime("%H:%M") %></span>
        <%= button_to stop_time_entry_path(running), method: :patch, class: "btn btn--primary btn--sm",
              params: { return_to: task_path(@task, anchor: "tab-time") } do %>
          <%= action_icon("stop") %> Parar timer
        <% end %>
      <% else %>
        <%= button_to task_timer_path(@task), method: :post, class: "btn btn--primary btn--sm" do %>
          <%= action_icon("play") %> Iniciar timer
        <% end %>
      <% end %>
      <%# PB-013b — novo apontamento criado pela tarefa retorna à tarefa (#tab-time). %>
      <%= link_to "Novo apontamento retroativo", new_time_entry_path(task_id: @task.id, return_to: task_path(@task, anchor: "tab-time")), class: "btn btn--outline btn--sm" %>
    </div>
  </div>

  <% if entries.any? %>
    <table class="te-history">
      <thead>
        <tr>
          <th>Descrição</th><th>Início</th><th>Término</th>
          <th class="te-col-duration">Duração</th><th>Ações</th>
        </tr>
      </thead>
      <%# PB-003b — um grupo por data (mais recente → mais antiga); itens por horário (desc). %>
      <% entries.group_by(&:date).sort_by { |date, _| date }.reverse.each do |date, day_entries| %>
        <% day_total = day_entries.reject(&:is_running).sum(&:duration) %>
        <tbody class="te-day">
          <tr class="te-day__head">
            <th colspan="5"><%= date&.strftime("%d/%m/%Y") %> · <%= day_entries.size %> apontamento(s)</th>
          </tr>
          <% day_entries.each do |entry| %>
            <tr>
              <td class="te-desc"><%= entry.description.presence || "—" %></td>
              <td><%= entry.start_time&.strftime("%H:%M") || "—" %></td>
              <td>
                <% if entry.end_time %><%= entry.end_time.strftime("%H:%M") %>
                <% elsif entry.is_running %><span class="badge badge--info">em andamento</span>
                <% else %>—<% end %>
              </td>
              <td class="te-col-duration">
                <% if entry.is_running %><span class="muted">—</span>
                <% else %><strong><%= duration_label(entry.duration) %></strong><% end %>
              </td>
              <td>
                <%# PB-003a — ações na linha. PB-013b: Ver/Editar/Parar/Excluir voltam à
                    tarefa (#tab-time), pois a origem foi a própria tarefa. %>
                <% te_back = task_path(@task, anchor: "tab-time") %>
                <div class="te-actions">
                  <%= link_to action_icon("eye"), time_entry_path(entry, return_to: te_back), class: "btn btn--ghost btn--icon te-action--view",
                        title: "Ver", "aria-label": "Ver apontamento" %>
                  <%= link_to action_icon("pencil"), edit_time_entry_path(entry, return_to: te_back), class: "btn btn--ghost btn--icon te-action--edit",
                        title: "Editar", "aria-label": "Editar apontamento" %>
                  <% if entry.is_running %>
                    <%= button_to action_icon("stop"), stop_time_entry_path(entry), method: :patch,
                          class: "btn btn--ghost btn--icon te-action--stop", form_class: "inline",
                          params: { return_to: te_back },
                          title: "Parar timer", "aria-label": "Parar timer deste apontamento" %>
                  <% end %>
                  <%= button_to action_icon("trash"), time_entry_path(entry), method: :delete,
                        class: "btn btn--ghost btn--icon te-action--delete", form_class: "inline",
                        params: { return_to: te_back },
                        title: "Excluir", "aria-label": "Excluir apontamento",
                        data: { turbo_confirm: "Excluir este apontamento?" } %>
                </div>
              </td>
            </tr>
          <% end %>
          <tr class="te-day__subtotal">
            <td colspan="3">Subtotal do dia</td>
            <td class="te-col-duration"><strong><%= duration_label(day_total) %></strong></td>
            <td></td>
          </tr>
        </tbody>
      <% end %>
      <%# PB-003c — total geral DENTRO da tabela (mesma grade dos subtotais):
          rótulo nas 3 primeiras colunas, valor na coluna Duração, Ações vazia. %>
      <tfoot>
        <tr class="te-total">
          <td colspan="3">Total de duração</td>
          <td class="te-col-duration"><strong><%= duration_label(@task.total_duration) %></strong></td>
          <td></td>
        </tr>
      </tfoot>
    </table>
    <p class="muted te-overlap-note">Os totais representam tempo lançado. Com apontamentos ou timers paralelos, podem exceder o tempo cronológico.</p>
  <% else %>
    <div class="empty">
      <p>Nenhum apontamento nesta tarefa.</p>
      <%# PB-013b — novo apontamento criado pela tarefa retorna à tarefa (#tab-time). %>
      <%= link_to "Novo apontamento retroativo", new_time_entry_path(task_id: @task.id, return_to: task_path(@task, anchor: "tab-time")), class: "btn btn--outline btn--sm" %>
    </div>
  <% end %>
</section>

<%# F4 — conversas vinculadas (read-only). Sem turnos/conteúdo/markdown. %>
<section class="tab-panel" id="tab-conversas">
  <h2>Conversas vinculadas</h2>
  <% if @linked_conversations.any? %>
    <table>
      <thead>
        <tr><th>Conversa</th><th>Source</th><th>Vínculo</th><th>Origem</th><th>Última atividade</th><th></th></tr>
      </thead>
      <tbody>
        <% @linked_conversations.each do |link| %>
          <% conv = link.conversation %>
          <tr>
            <td><%= conv.title.presence || tag.span("— sem título —", class: "muted") %></td>
            <td><%= status_badge(conv.source) %></td>
            <td><%= tag.span(link.link_type, class: "badge badge--#{link.link_type == 'primary' ? 'info' : 'neutral'}") %></td>
            <td><%= link.origin %></td>
            <td><%= conv.last_ts&.strftime("%d/%m/%Y %H:%M") || "—" %></td>
            <td><%= link_to "Ver", conversation_path(conv), class: "btn btn--ghost btn--sm" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="muted">Nenhuma conversa vinculada a esta tarefa.</p>
  <% end %>
</section>
<section class="tab-panel placeholder" id="tab-historico">
  Histórico operacional será exibido aqui em fase futura.
</section>
<%# PB-004c — demanda de ORIGEM da tarefa (0 ou 1). %>
<section class="tab-panel" id="tab-demanda">
  <h2>Demanda de origem</h2>
  <% if @origin_demand %>
    <% d = @origin_demand %>
    <div class="card">
      <dl>
        <dt>Título</dt><dd><%= link_to d.title, demand_path(d) %></dd>
        <dt>Descrição</dt><dd><%= d.description.presence || "—" %></dd>
        <dt>Origem</dt><dd><%= d.origin&.humanize || "—" %></dd>
        <dt>Prioridade</dt><dd><%= status_badge(d.priority) %></dd>
        <dt>Status</dt><dd><%= status_badge(d.status) %></dd>
        <dt>Convertida em</dt><dd><%= d.converted_at&.strftime("%d/%m/%Y %H:%M") || "—" %></dd>
      </dl>
      <%= link_to "Abrir demanda", demand_path(d), class: "btn btn--outline btn--sm" %>
    </div>
  <% else %>
    <p class="muted">Esta tarefa não foi criada a partir de uma demanda.</p>
  <% end %>
</section>

<p><%= link_to "Voltar", (@return_to.presence || tasks_path), class: "back-link" %></p>
