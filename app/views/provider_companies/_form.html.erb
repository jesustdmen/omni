<%= form_with model: provider_company, url: (provider_company.persisted? ? provider_company_path(provider_company) : provider_companies_path) do |f| %>
  <%= hidden_field_tag :return_to, @return_to if @return_to.present? %><%# PB-013b %>
  <% if provider_company.errors.any? %>
    <div class="errors">
      <p><%= pluralize(provider_company.errors.count, "erro") %> impediram salvar:</p>
      <ul>
        <% provider_company.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div><%= f.label :name, "Razão social / nome" %><br><%= f.text_field :name %></div>
  <div><%= f.label :trade_name, "Nome fantasia" %><br><%= f.text_field :trade_name %></div>
  <div><%= f.label :cnpj, "CNPJ (opcional)" %><br><%= f.text_field :cnpj, value: format_cnpj(provider_company.cnpj) %></div>
  <div><%= f.label :email, "E-mail" %><br><%= f.email_field :email %></div>
  <div><%= f.label :phone, "Telefone" %><br><%= f.text_field :phone %></div>
  <div><%= f.label :address, "Endereço" %><br><%= f.text_field :address %></div>
  <div><label><%= f.check_box :active %> Ativa</label></div>

  <div>
    <%= f.submit %>
    <%# PB-013b — Cancelar volta à origem; senão à lista. %>
    <%= link_to "Cancelar", (@return_to.presence || provider_companies_path), class: "btn btn--ghost btn--sm" %>
  </div>
<% end %>
