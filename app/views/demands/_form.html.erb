<%= form_with model: demand do |f| %>
  <%= hidden_field_tag :return_to, @return_to if @return_to.present? %><%# PB-013b %>
  <% if demand.errors.any? %>
    <div class="errors">
      <p><%= pluralize(demand.errors.count, "erro") %> impediram salvar:</p>
      <ul>
        <% demand.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div><%= f.label :title, "Título" %><br><%= f.text_field :title %></div>
  <div>
    <%= f.label :origin, "Origem" %><br>
    <%= f.select :origin, options_for_select(Demand::ORIGINS.map { |o| [o.humanize, o] }, demand.origin), prompt: "Selecione a origem" %>
  </div>
  <div>
    <%= f.label :priority, "Prioridade" %><br>
    <%= f.select :priority, options_for_select(Demand::PRIORITIES.map { |p| [p.humanize, p] }, demand.priority), prompt: "Selecione a prioridade" %>
  </div>
  <div>
    <%= f.label :client_id, "Cliente (opcional)" %><br>
    <%= f.collection_select :client_id, Client.order(:name), :id, :name, include_blank: "— sem cliente —" %>
  </div>
  <div><%= f.label :description, "Descrição" %><br><%= f.text_area :description, rows: 3 %></div>
  <div><%= f.label :observations, "Observações" %><br><%= f.text_area :observations, rows: 2 %></div>

  <div>
    <%= f.submit %>
    <%# PB-013b — Cancelar volta à origem; senão ao detalhe (edição) ou à lista (novo). %>
    <%= link_to "Cancelar", (@return_to.presence || (demand.persisted? ? demand : demands_path)), class: "btn btn--ghost btn--sm" %>
  </div>
<% end %>
