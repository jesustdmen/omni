<% content_for :title, @demand.title %>

<%# PB-013b — breadcrumb acessível; preserva a origem (lista/busca filtrada). %>
<nav class="breadcrumb" aria-label="Breadcrumb">
  <%= link_to "Demandas", (@return_to.presence || demands_path) %>
  <span class="sep">/</span>
  <span><%= @demand.title %></span>
</nav>

<div class="page-head">
  <div class="page-head__titles">
    <h1><%= @demand.title %></h1>
    <div class="badge-row">
      <%= status_badge(@demand.status, label: @demand.status_label) %>
      <%= status_badge(@demand.priority) %>
    </div>
  </div>
  <div class="page-head__actions">
    <%= link_to "Editar", edit_demand_path(@demand, return_to: @return_to), class: "btn btn--outline btn--sm" %>
    <%= button_to "Excluir", demand_path(@demand, return_to: @return_to), method: :delete,
          class: "btn btn--ghost btn--sm", form_class: "inline",
          data: { turbo_confirm: "Excluir demanda?" } %>
  </div>
</div>

<div class="card">
  <dl>
    <dt>Origem</dt><dd><%= @demand.origin.present? ? @demand.origin_label : "—" %></dd>
    <dt>Prioridade</dt><dd><%= @demand.priority_label %></dd>
    <dt>Cliente</dt><dd><%= @demand.client ? link_to(@demand.client.name, @demand.client) : "—" %></dd>
    <dt>Status</dt><dd><%= @demand.status_label %></dd>
    <dt>Descrição</dt><dd><%= @demand.description.presence || "—" %></dd>
    <dt>Observações</dt><dd><%= @demand.observations.presence || "—" %></dd>
    <% if @demand.converted? %>
      <dt>Convertida em</dt><dd><%= @demand.converted_at %></dd>
    <% end %>
  </dl>
</div>

<% if @demand.pending? %>
  <div class="convert">
    <%= button_to "Converter em tarefa", convert_demand_path(@demand), method: :post %>
  </div>
<% else %>
  <%# PB-004c — convertida: link claro para a tarefa criada; sem oferecer nova conversão. %>
  <div class="converted-state">
    <p><span aria-hidden="true">✓</span> Demanda convertida em tarefa.</p>
    <% if @converted_task %>
      <%# PB-014 — link da tarefa exibe o código. %>
      <%= link_to "Abrir #{@converted_task.code}", task_path(@converted_task), class: "btn btn--outline btn--sm" %>
    <% end %>
  </div>
<% end %>

<%= link_to "Voltar", (@return_to.presence || demands_path), class: "back-link" %>
