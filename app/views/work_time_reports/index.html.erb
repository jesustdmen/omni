<% content_for :title, "Apuração de horas" %>

<div class="page-head">
  <div class="page-head__titles">
    <h1>Apuração de horas</h1>
    <p class="page-head__sub">Horas trabalhadas por período, cliente, projeto e tarefa. Somente consolidação — sem valor.</p>
  </div>
</div>

<%# PB-020a — filtros (GET; preserva via query params). Período por dia operacional (Brasília). %>
<%= form_with url: work_time_reports_path, method: :get, class: "filters" do |f| %>
  <label>De <%= f.date_field :start_date, value: @start_date.iso8601 %></label>
  <label>Até <%= f.date_field :end_date, value: @end_date.iso8601 %></label>
  <%= f.select :client_id, options_for_select([ [ "Cliente: todos", "" ] ] + @clients, @client_id) %>
  <%= f.select :project_id, options_for_select([ [ "Projeto: todos", "" ] ] + @projects, @project_id) %>
  <label class="filters__check">
    <%= f.check_box :include_without_hours, { checked: @include_without_hours }, "true", "" %>
    Mostrar tarefas sem horas lançadas (com conversas)
  </label>
  <%= f.submit "Apurar", class: "btn btn--primary btn--sm" %>
  <%= link_to "Limpar", work_time_reports_path, class: "btn btn--ghost btn--sm" %>
<% end %>

<%# Resumo do período. %>
<div class="card wtr-summary">
  <div class="subhead"><h2>Resumo do período</h2></div>
  <p class="muted">
    <%= local_date(@start_date) %> → <%= local_date(@end_date) %>
  </p>
  <ul class="wtr-totals">
    <li><strong>Total de horas apuradas:</strong> <%= duration_label(@report.totals.seconds) %></li>
    <li><strong>Apontamentos:</strong> <%= @report.totals.entries_count %></li>
    <li><strong>Tarefas:</strong> <%= @report.totals.tasks_count %></li>
    <li><strong>Conversas vinculadas (evidências):</strong> <%= @report.totals.conversations_count %></li>
    <li><strong>Tarefas sem horas lançadas:</strong> <%= @report.totals.tasks_without_hours %></li>
  </ul>
</div>

<% rows = @report.rows %>
<% if rows.any? %>
  <table class="projects-list wtr-table">
    <thead>
      <tr>
        <th>Tarefa</th><th>Cliente</th><th>Projeto</th>
        <th>Horas apuradas</th><th>Apontamentos</th><th>Conversas vinculadas</th>
      </tr>
    </thead>
    <tbody>
      <% rows.each do |row| %>
        <tr class="<%= "wtr-row--no-hours" unless row.with_hours? %>">
          <td class="projects-list__name">
            <%= task_code_tag(row.task) %> <%= link_to row.task.title, row.task %>
          </td>
          <td><%= row.task.client.name %></td>
          <td><%= row.task.project&.name || "—" %></td>
          <td>
            <% if row.with_hours? %>
              <%= duration_label(row.seconds) %>
            <% else %>
              <span class="badge badge--neutral">Sem horas lançadas</span>
            <% end %>
          </td>
          <td><%= row.entries_count %></td>
          <td><%= row.conversations_count %></td>
        </tr>
      <% end %>
    </tbody>
    <tfoot>
      <tr>
        <td colspan="3"><strong>Total do período</strong></td>
        <td><strong><%= duration_label(@report.totals.seconds) %></strong></td>
        <td><strong><%= @report.totals.entries_count %></strong></td>
        <td><strong><%= @report.totals.conversations_count %></strong></td>
      </tr>
    </tfoot>
  </table>

  <%# Totais por cliente e por projeto. %>
  <div class="wtr-breakdowns">
    <div class="card">
      <div class="subhead"><h2>Total por cliente</h2></div>
      <ul class="wtr-breakdown">
        <% @report.seconds_by_client.sort_by { |_id, secs| -secs }.each do |client_id, secs| %>
          <li><span><%= @client_names[client_id] || "—" %></span> <span><%= duration_label(secs) %></span></li>
        <% end %>
      </ul>
    </div>
    <div class="card">
      <div class="subhead"><h2>Total por projeto</h2></div>
      <ul class="wtr-breakdown">
        <% @report.seconds_by_project.sort_by { |_id, secs| -secs }.each do |project_id, secs| %>
          <li><span><%= project_id ? (@project_names[project_id] || "—") : "Sem projeto" %></span> <span><%= duration_label(secs) %></span></li>
        <% end %>
      </ul>
    </div>
  </div>
<% else %>
  <div class="empty">
    <p>Nenhuma hora apurada no período com os filtros atuais.</p>
    <%= link_to "Limpar filtros", work_time_reports_path, class: "btn btn--outline btn--sm" %>
  </div>
<% end %>
