<% content_for :title, "Sincronização de conversas" %>

<%# PB-015 — enquanto há execução ativa, atualiza a página sozinha (sem JS) para
    refletir progresso/conclusão; ao terminar, o refresh para. %>
<% if @active_execution %>
  <% content_for :head do %><meta http-equiv="refresh" content="3"><% end %>
<% end %>

<div class="page-head">
  <div class="page-head__titles">
    <h1>Sincronização de conversas</h1>
    <%# PB-016a — quando o pipeline interno está ligado, o botão faz coleta + importação. %>
    <% if @pipeline_internal %>
      <p class="page-head__sub">Coleta as conversas mais recentes (VS Code/Codex/Claude), normaliza e importa no Omni — tudo aqui, sem PowerShell nem Tarefa do Windows.</p>
    <% else %>
      <p class="page-head__sub">Importa o output normalizado já disponível para o Omni. Lê apenas a fonte fixa; o pipeline interno está desligado.</p>
    <% end %>
  </div>
</div>

<%# PB-016a — painel operacional: ação principal + status agregado da última execução. %>
<div class="card sync-panel">
  <% active = @active_execution %>
  <div class="sync-panel__action">
    <%= button_to "Sincronizar agora",
          sync_executions_path, method: :post,
          class: "btn btn--primary",
          disabled: active.present?,
          data: { turbo_confirm: @pipeline_internal ? "Coletar e importar as conversas agora?" : "Importar as conversas disponíveis agora?" } %>
    <% if @pipeline_internal %>
      <span class="muted">Executa <strong>coleta + importação</strong> em segundo plano.</span>
    <% else %>
      <span class="muted">Importa os arquivos disponíveis (coleta pelo Omni desligada).</span>
    <% end %>
    <% if active %>
      <span class="muted">Há uma sincronização <strong><%= active.status %></strong> em andamento — aguarde concluir.</span>
    <% end %>
  </div>

  <%# PB-016a — opção secundária: só importar o que já existe (sem coletar), útil
      quando o pipeline interno está ligado mas o operador quer apenas reimportar. %>
  <% if @pipeline_internal %>
    <div class="sync-panel__secondary">
      <%= button_to "Importar arquivos disponíveis",
            sync_executions_path(only_import: "1"), method: :post,
            class: "btn btn--ghost btn--sm",
            disabled: active.present?,
            data: { turbo_confirm: "Importar apenas o output já disponível (sem coletar)?" } %>
      <span class="muted">Pula a coleta; importa o output normalizado atual.</span>
    </div>
  <% end %>

  <%# PB-016a — estado do agente de coleta (host) quando o pipeline interno está ligado. %>
  <% if @pipeline_internal %>
    <div class="sync-agent">
      <span class="muted">Agente de coleta (host):</span>
      <% if @agent_online %>
        <span class="badge badge--info">online</span>
      <% else %>
        <span class="badge badge--neutral">offline</span>
        <span class="muted">— a coleta será pulada; a importação do output atual ainda ocorre.</span>
      <% end %>
    </div>
  <% end %>

  <%# PB-016a — agendamento interno (modo agendado, além do manual). Sem JS. %>
  <div class="sync-schedule">
    <%= form_with model: @schedule, url: sync_schedule_path, method: :patch, class: "sync-schedule__form" do |f| %>
      <span class="sync-schedule__title">Agendamento automático</span>
      <label class="sync-schedule__toggle">
        <%= f.check_box :enabled %> Ativado
      </label>
      <label>
        A cada
        <%= f.select :interval_minutes,
              options_for_select(SyncSchedule::INTERVAL_OPTIONS.map { |m| [ m < 60 ? "#{m} min" : "#{m / 60} h", m ] }, @schedule.interval_minutes) %>
      </label>
      <%= f.submit "Salvar agendamento", class: "btn btn--outline btn--sm" %>
      <% if @schedule.enabled %>
        <span class="muted">
          Ativo (a cada <%= @schedule.interval_label %>)<% if @schedule.last_enqueued_at %> · último disparo <%= @schedule.last_enqueued_at.strftime("%d/%m/%Y %H:%M") %><% end %>.
        </span>
      <% else %>
        <span class="muted">Desativado — sincronize manualmente pelo botão acima.</span>
      <% end %>
    <% end %>
  </div>

  <%# PB-016a — indicador de progresso por etapa (só durante execução ativa). %>
  <% if active %>
    <div class="sync-progress" role="status" aria-live="polite">
      <div class="sync-progress__head">
        <span><%= active.queued? ? "Aguardando processamento…" : "Etapa: #{active.current_step_title || '—'}" %></span>
        <span class="sync-progress__pct"><%= active.steps_done %>/<%= active.steps_total %> · <%= active.progress_percent %>%</span>
      </div>
      <div class="sync-progress__bar" aria-hidden="true">
        <div class="sync-progress__fill" style="width: <%= active.progress_percent %>%"></div>
      </div>
      <p class="muted sync-progress__hint">Esta página atualiza sozinha enquanto a sincronização roda.</p>
    </div>
  <% end %>

  <% last = @last_execution %>
  <% if last %>
    <div class="sync-status">
      <div class="sync-status__row">
        <span class="sync-status__label">Última execução</span>
        <%= status_badge(last.status) %>
        <span class="muted"><%= (last.finished_at || last.started_at || last.created_at)&.strftime("%d/%m/%Y %H:%M") %></span>
        <% if last.duration_seconds %><span class="muted">· <%= duration_label(last.duration_seconds) %></span><% end %>
      </div>
      <% if last.status == "error" && last.error_message.present? %>
        <p class="sync-status__error">Erro: <%= last.error_message %></p>
      <% end %>
      <%# PB-016a — resumo seguro do pipeline (quando executado). %>
      <% if last.pipeline_exit_code.present? || last.pipeline_summary.present? %>
        <p class="muted sync-status__pipeline">Pipeline: <%= last.pipeline_summary.presence || "exit=#{last.pipeline_exit_code}" %></p>
      <% end %>
      <%# Contadores agregados das etapas (SyncRun) desta execução. %>
      <% runs = last.sync_runs.order(:created_at) %>
      <% if runs.any? %>
        <table class="sync-status__counters">
          <thead><tr><th>Etapa</th><th>Status</th><th>Linhas</th><th>Importadas</th><th>Atualizadas</th><th>Puladas</th><th>Erros</th></tr></thead>
          <tbody>
            <% runs.each do |r| %>
              <tr>
                <td><%= r.source_label %></td>
                <td><%= status_badge(r.status) %></td>
                <td><%= r.lines_processed %></td>
                <td><%= r.imported %></td>
                <td><%= r.updated %></td>
                <td><%= r.skipped %></td>
                <td><%= r.error_lines %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>
    </div>
  <% else %>
    <p class="muted">Nenhuma sincronização operacional executada ainda.</p>
  <% end %>
</div>

<h2 class="sync-history-title">Histórico de execuções (auditoria)</h2>
<% if @sync_runs.any? %>
  <table>
    <thead>
      <tr><th>Quando</th><th>Fonte</th><th>Schema</th><th>Status</th><th>Linhas</th><th>Imported</th><th>Updated</th><th>Skipped</th><th>Erros</th><th></th></tr>
    </thead>
    <tbody>
      <% @sync_runs.each do |run| %>
        <tr>
          <td><%= (run.finished_at || run.created_at)&.strftime("%d/%m/%Y %H:%M") %></td>
          <td><%= run.source_label || "—" %></td>
          <td><%= run.schema_version || "—" %></td>
          <td><%= status_badge(run.status) %></td>
          <td><%= run.lines_processed %></td>
          <td><%= run.imported %></td>
          <td><%= run.updated %></td>
          <td><%= run.skipped %></td>
          <td><%= run.error_lines %></td>
          <td><%= link_to "Ver", sync_run_path(run), class: "btn btn--ghost btn--sm" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="empty"><p>Nenhum sync run registrado.</p></div>
<% end %>
