<% content_for :title, "Sync runs" %>

<div class="page-head">
  <div class="page-head__titles">
    <h1>Sync runs</h1>
    <p class="page-head__sub">Console read-only de validação da Fase 3 — execuções de importação (auditoria).</p>
  </div>
</div>

<% if @sync_runs.any? %>
  <table>
    <thead>
      <tr><th>Quando</th><th>Fonte</th><th>Schema</th><th>Status</th><th>Linhas</th><th>Imported</th><th>Updated</th><th>Skipped</th><th>Erros</th><th></th></tr>
    </thead>
    <tbody>
      <% @sync_runs.each do |run| %>
        <tr>
          <td><%= (run.finished_at || run.created_at)&.strftime("%d/%m/%Y %H:%M") %></td>
          <td><%= run.source_label || "—" %></td>
          <td><%= run.schema_version || "—" %></td>
          <td><%= status_badge(run.status) %></td>
          <td><%= run.lines_processed %></td>
          <td><%= run.imported %></td>
          <td><%= run.updated %></td>
          <td><%= run.skipped %></td>
          <td><%= run.error_lines %></td>
          <td><%= link_to "Ver", sync_run_path(run), class: "btn btn--ghost btn--sm" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="empty"><p>Nenhum sync run registrado.</p></div>
<% end %>
