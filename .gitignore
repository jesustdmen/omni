# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore all environment files.
/.env*

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Ignore key files for decrypting credentials and more.
/config/*.key

# Proteção defensiva contra dumps/snapshots/exportações de banco (higiene SEC-DUMP).
# Não bloqueia arquivos do Rails; alvo são despejos de dados sensíveis.
*.tgz
*.tar
*.dump
*.backup
*.bak
*.sql
postgres-volume-snapshot-*


# PB-016a — bytecode do agente Python (host)
script/__pycache__/
*.pyc

# F7.7 — pipeline NATIVO de coleta/normalização (app/pipeline). Versiona-se o CÓDIGO,
# nunca os DADOS/saída gerados: snapshots raw, output normalizado (~250 MB sessions.jsonl),
# state incremental, caches, bytecode e bancos SQLite (podem conter conteúdo de conversa).
# Indispensável para a F7.7 (internalização do pipeline). Não confundir com diffs de Graphify.
/pipeline/output/
/app/pipeline/output/
/pipeline/.venv/
/app/pipeline/.venv/
/pipeline/**/__pycache__/
/app/pipeline/**/__pycache__/
/pipeline/**/*.pyc
/app/pipeline/**/*.pyc
/pipeline/**/*.sqlite
/pipeline/**/*.sqlite3
/pipeline/**/*.db
/pipeline/**/*.db-wal
/pipeline/**/*.db-shm
/app/pipeline/**/*.sqlite
/app/pipeline/**/*.sqlite3
/app/pipeline/**/*.db
/app/pipeline/**/*.db-wal
/app/pipeline/**/*.db-shm
